# Default: normalize line endings to LF
* text=auto eol=lf

# Force LF for shell, Python, TS, C#, YAML, JSON, MD
*.sh         text eol=lf
*.py         text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.cs         text eol=lf
*.csproj     text eol=lf
*.sln        text eol=lf
*.svelte     text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.toml       text eol=lf

# Windows-only
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Binary
*.png        binary
*.jpg        binary
*.ico        binary
*.icns       binary
*.dll        binary
*.so         binary
*.dylib      binary
*.exe        binary
