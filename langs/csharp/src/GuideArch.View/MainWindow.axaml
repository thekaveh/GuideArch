<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scottplot="using:ScottPlot.Avalonia"
        xmlns:local="using:GuideArch.View"
        x:Class="GuideArch.View.MainWindow"
        Title="GuideArch"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BgPageBrush}"
        FontSize="13">

  <!--
    DataContext is ComponentVM<ScenarioState> — an open generic type that Avalonia's
    compiled-binding engine cannot resolve without a type literal. All bindings into
    the VM use ReflectionBinding intentionally throughout this file.
  -->

  <Window.Resources>
    <local:StringJoinConverter x:Key="StringJoin" />
  </Window.Resources>

  <DockPanel>

    <!-- ================================================================
         TOP TOOLBAR — §6 toolbar: 56px tall, 24px horizontal padding
         ================================================================ -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Height="56"
            Padding="24,0">
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">

        <!-- New -->
        <Button Name="BtnNew"
                Content="New"
                ToolTip.Tip="New scenario"
                Classes="toolbar-btn"
                Click="OnNewClicked" />

        <!-- Open -->
        <Button Name="BtnOpen"
                Content="Open…"
                ToolTip.Tip="Open scenario JSON"
                Classes="toolbar-btn"
                Click="OnOpenClicked" />

        <!-- Open Sample SAS -->
        <Button Name="BtnOpenSampleSas"
                Content="Open Sample SAS"
                ToolTip.Tip="Load the bundled SAS (Service-Oriented Architecture) sample"
                Classes="toolbar-btn"
                Click="OnOpenSampleSasClicked" />

        <!-- Open Sample EDS -->
        <Button Name="BtnOpenSampleEds"
                Content="Open Sample EDS"
                ToolTip.Tip="Load the bundled EDS (Enterprise Decision Space) sample"
                Classes="toolbar-btn"
                Click="OnOpenSampleEdsClicked" />

        <!-- Save -->
        <Button Name="BtnSave"
                Content="Save"
                ToolTip.Tip="Save current scenario"
                Classes="toolbar-btn"
                Click="OnSaveClicked"
                IsEnabled="{ReflectionBinding Model.CanSave}" />

        <!-- Save As -->
        <Button Name="BtnSaveAs"
                Content="Save As…"
                ToolTip.Tip="Save as new file"
                Classes="toolbar-btn"
                Click="OnSaveAsClicked"
                IsEnabled="{ReflectionBinding Model.HasScenario}" />

        <!-- Flexible spacer -->
        <Panel HorizontalAlignment="Stretch" />

        <!-- Solve -->
        <Button Name="BtnSolve"
                Content="Solve"
                ToolTip.Tip="Re-run TOPSIS"
                Classes="toolbar-btn"
                Click="OnSolveClicked"
                IsEnabled="{ReflectionBinding Model.HasScenario}" />

      </StackPanel>
    </Border>

    <!-- ================================================================
         BOTTOM STATUS BAR — §6 status bar: 32px tall, 24px horizontal padding
         ================================================================ -->
    <Border DockPanel.Dock="Bottom"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Height="32"
            Padding="24,0">
      <Grid ColumnDefinitions="*,Auto">
        <!-- Status text — scenario name · n candidates -->
        <TextBlock Grid.Column="0"
                   Text="{ReflectionBinding Model.Status}"
                   FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   VerticalAlignment="Center" />
        <!-- Warnings chip — shows last warning if any -->
        <TextBlock Grid.Column="1"
                   Text="{ReflectionBinding Model.Warnings[0]}"
                   FontSize="11"
                   Foreground="{StaticResource DangerBrush}"
                   VerticalAlignment="Center"
                   Margin="16,0,0,0"
                   IsVisible="{ReflectionBinding !Model.Warnings.IsEmpty}" />
      </Grid>
    </Border>

    <!-- ================================================================
         MAIN CONTENT — tab strip always visible (§8 empty state inside tabs)
         ================================================================ -->
    <Panel>

      <!-- ── Tab strip — always visible ──────────────────────────────── -->
      <TabControl Name="MainTabs"
                  Background="{StaticResource BgPageBrush}">

      <!-- ── Tab 1: Decisions ────────────────────────────────────────── -->
      <TabItem Header="Decisions">
        <Grid RowDefinitions="Auto,*">

          <!-- Add Decision toolbar -->
          <StackPanel Grid.Row="0"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="24,12,24,8"
                      IsVisible="{ReflectionBinding Model.HasScenario}">
            <Button Content="Add Decision"
                    Click="OnAddDecisionClicked"
                    Classes="action-btn" />
          </StackPanel>

          <!-- Decisions list -->
          <!-- ReflectionBinding: open generic DataContext (see file header) -->
          <DataGrid Grid.Row="1"
                    Name="DecisionsGrid"
                    ItemsSource="{ReflectionBinding Model.DecisionsView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID"
                                  Binding="{ReflectionBinding Id}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Name"
                                  Binding="{ReflectionBinding Name}"
                                  Width="*" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 2: Alternatives ─────────────────────────────────────── -->
      <TabItem Header="Alternatives">
        <Grid RowDefinitions="Auto,*">

          <!-- Per-decision Add Alternative — handled in code-behind -->
          <StackPanel Grid.Row="0"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="24,12,24,8"
                      IsVisible="{ReflectionBinding Model.HasScenario}">
            <TextBlock Text="Select a decision then:"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
            <Button Content="Add Alternative"
                    Click="OnAddAlternativeClicked"
                    Classes="action-btn" />
          </StackPanel>

          <!-- Alternatives grouped by decision -->
          <!-- ReflectionBinding: open generic DataContext (see file header) -->
          <DataGrid Grid.Row="1"
                    Name="AlternativesGrid"
                    ItemsSource="{ReflectionBinding Model.AlternativesView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID"
                                  Binding="{ReflectionBinding Id}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Decision ID"
                                  Binding="{ReflectionBinding DecisionId}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Name"
                                  Binding="{ReflectionBinding Name}"
                                  Width="*" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 3: Properties ──────────────────────────────────────── -->
      <TabItem Header="Properties">
        <Grid RowDefinitions="Auto,*">

          <StackPanel Grid.Row="0"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="24,12,24,8"
                      IsVisible="{ReflectionBinding Model.HasScenario}">
            <Button Content="Add Property"
                    Click="OnAddPropertyClicked"
                    Classes="action-btn" />
          </StackPanel>

          <!-- Properties table -->
          <!-- ReflectionBinding: open generic DataContext (see file header) -->
          <DataGrid Grid.Row="1"
                    Name="PropertiesGrid"
                    ItemsSource="{ReflectionBinding Model.PropertiesView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID"
                                  Binding="{ReflectionBinding Id}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Name"
                                  Binding="{ReflectionBinding Name}"
                                  Width="*" />
              <DataGridTextColumn Header="Kind"
                                  Binding="{ReflectionBinding Kind}"
                                  Width="80" />
              <DataGridTextColumn Header="Weight"
                                  Binding="{ReflectionBinding Weight, StringFormat={}{0:F4}}"
                                  Width="100"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 4: Coefficients ────────────────────────────────────── -->
      <TabItem Header="Coefficients">
        <Grid RowDefinitions="Auto,*">

          <TextBlock Grid.Row="0"
                     Text="Fuzzy coefficient matrix: rows = alternatives (grouped by decision), columns = properties."
                     Margin="24,12,24,8"
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     IsVisible="{ReflectionBinding Model.HasScenario}" />

          <!-- 2-D matrix: built in code-behind, hosted here -->
          <ScrollViewer Grid.Row="1"
                        Name="CoefficientsScroll"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        Margin="24,0,24,24"
                        IsVisible="{ReflectionBinding Model.HasScenario}">
            <ContentControl Name="CoefficientsContent" />
          </ScrollViewer>

        </Grid>
      </TabItem>

      <!-- ── Tab 5: Constraints ─────────────────────────────────────── -->
      <TabItem Header="Constraints">
        <TabControl Background="{StaticResource BgPageBrush}"
                    IsVisible="{ReflectionBinding Model.HasScenario}">

          <!-- Sub-tab: Threshold -->
          <TabItem Header="Threshold">
            <Grid RowDefinitions="Auto,*">

              <StackPanel Grid.Row="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="24,12,24,8">
                <Button Content="Add Threshold"
                        Click="OnAddThresholdClicked"
                        Classes="action-btn" />
              </StackPanel>

              <!-- ReflectionBinding: open generic DataContext (see file header) -->
              <DataGrid Grid.Row="1"
                        Name="ThresholdGrid"
                        ItemsSource="{ReflectionBinding Model.ThresholdConstraintsView}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        Margin="24,0,24,24">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Property ID"
                                      Binding="{ReflectionBinding PropertyId}"
                                      Width="220"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                  <DataGridTextColumn Header="Min"
                                      Binding="{ReflectionBinding Min}"
                                      Width="120"
                                      FontFamily="Cascadia Code,Consolas,monospace" />
                  <DataGridTextColumn Header="Max"
                                      Binding="{ReflectionBinding Max}"
                                      Width="120"
                                      FontFamily="Cascadia Code,Consolas,monospace" />
                </DataGrid.Columns>
              </DataGrid>

            </Grid>
          </TabItem>

          <!-- Sub-tab: Dependency -->
          <TabItem Header="Dependency">
            <Grid RowDefinitions="Auto,*">

              <StackPanel Grid.Row="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="24,12,24,8">
                <Button Content="Add Dependency"
                        Click="OnAddDependencyClicked"
                        Classes="action-btn" />
              </StackPanel>

              <!-- ReflectionBinding: open generic DataContext (see file header) -->
              <DataGrid Grid.Row="1"
                        Name="DependencyGrid"
                        ItemsSource="{ReflectionBinding Model.DependencyConstraintsView}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        Margin="24,0,24,24">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Source Alternative ID"
                                      Binding="{ReflectionBinding SourceAlternativeId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                  <DataGridTextColumn Header="Target Alternative ID"
                                      Binding="{ReflectionBinding TargetAlternativeId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                </DataGrid.Columns>
              </DataGrid>

            </Grid>
          </TabItem>

          <!-- Sub-tab: Conflict -->
          <TabItem Header="Conflict">
            <Grid RowDefinitions="Auto,*">

              <StackPanel Grid.Row="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="24,12,24,8">
                <Button Content="Add Conflict"
                        Click="OnAddConflictClicked"
                        Classes="action-btn" />
              </StackPanel>

              <!-- ReflectionBinding: open generic DataContext (see file header) -->
              <DataGrid Grid.Row="1"
                        Name="ConflictGrid"
                        ItemsSource="{ReflectionBinding Model.ConflictConstraintsView}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        Margin="24,0,24,24">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Alternative A ID"
                                      Binding="{ReflectionBinding AlternativeAId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                  <DataGridTextColumn Header="Alternative B ID"
                                      Binding="{ReflectionBinding AlternativeBId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                </DataGrid.Columns>
              </DataGrid>

            </Grid>
          </TabItem>

        </TabControl>
      </TabItem>

      <!-- ── Tab 6: Results — split pane (M4) ──────────────────────── -->
      <TabItem Header="Results">
        <Grid RowDefinitions="Auto,*">

          <!-- Split: left 60% candidates table, right 40% charts -->
          <Grid Grid.Row="1"
                ColumnDefinitions="3*,2*"
                IsVisible="{ReflectionBinding Model.HasScenario}">

            <!-- Left: ranked candidates DataGrid -->
            <DataGrid Grid.Column="0"
                      Name="ResultsGrid"
                      ItemsSource="{ReflectionBinding Model.Candidates}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      IsReadOnly="True"
                      Margin="24,0,12,24"
                      SelectionChanged="OnResultsGridSelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Rank"
                                    Binding="{ReflectionBinding Rank}"
                                    Width="80"
                                    FontFamily="Cascadia Code,Consolas,monospace" />
                <DataGridTextColumn Header="Score"
                                    Binding="{ReflectionBinding Score, StringFormat={}{0:F6}}"
                                    Width="120"
                                    FontFamily="Cascadia Code,Consolas,monospace" />
                <DataGridTextColumn Header="Alternative IDs"
                                    Binding="{ReflectionBinding AlternativeIdsDisplay}"
                                    Width="*"
                                    FontFamily="Cascadia Code,Consolas,monospace"
                                    FontSize="13" />
              </DataGrid.Columns>
            </DataGrid>

            <!-- Right: two stacked ScottPlot charts -->
            <Grid Grid.Column="1"
                  RowDefinitions="*,*"
                  Margin="12,0,24,24">

              <!-- Chart A: horizontal bar chart of top 30 candidates (spec charts.md §2) -->
              <scottplot:AvaPlot Grid.Row="0"
                                 Name="ChartA"
                                 PointerPressed="OnChartAPointerPressed" />

              <!-- Chart B: triangle series for selected candidate (spec charts.md §3) -->
              <scottplot:AvaPlot Grid.Row="1"
                                 Name="ChartB" />

            </Grid>

          </Grid>

        </Grid>
      </TabItem>

      <!-- ── Tab 7: Critical Decisions (M4, spec charts.md §4) ─────── -->
      <TabItem Header="Critical Decisions">
        <Grid RowDefinitions="Auto,*">

          <TextBlock Grid.Row="0"
                     Text="Critical decisions — sorted ascending by rank (lower score = more critical)."
                     Margin="24,12,24,8"
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     IsVisible="{ReflectionBinding Model.HasScenario}" />

          <!-- ReflectionBinding: open generic DataContext -->
          <DataGrid Grid.Row="1"
                    Name="CriticalDecisionsGrid"
                    ItemsSource="{ReflectionBinding Model.CriticalDecisionsView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Rank"
                                  Binding="{ReflectionBinding Rank}"
                                  Width="80"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Decision"
                                  Binding="{ReflectionBinding DecisionName}"
                                  Width="*" />
              <DataGridTextColumn Header="Score"
                                  Binding="{ReflectionBinding Score}"
                                  Width="120"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Triangular value"
                                  Binding="{ReflectionBinding TriangularValue}"
                                  Width="200"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Normalized"
                                  Binding="{ReflectionBinding Normalized}"
                                  Width="200"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 8: Critical Constraints (M4, spec charts.md §5) ───── -->
      <TabItem Header="Critical Constraints">
        <Grid RowDefinitions="Auto,*">

          <TextBlock Grid.Row="0"
                     Text="Critical constraints — sorted descending by eliminated (most-binding first). Redundant rows are faded."
                     Margin="24,12,24,8"
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     IsVisible="{ReflectionBinding Model.HasScenario}" />

          <!-- ReflectionBinding: open generic DataContext -->
          <DataGrid Grid.Row="1"
                    Name="CriticalConstraintsGrid"
                    ItemsSource="{ReflectionBinding Model.CriticalConstraintsView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Index"
                                  Binding="{ReflectionBinding Index}"
                                  Width="80"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Kind"
                                  Binding="{ReflectionBinding Kind}"
                                  Width="120" />
              <DataGridTextColumn Header="Eliminated"
                                  Binding="{ReflectionBinding Eliminated}"
                                  Width="110"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Total"
                                  Binding="{ReflectionBinding Total}"
                                  Width="90"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Eliminated %"
                                  Binding="{ReflectionBinding EliminatedPercent}"
                                  Width="120"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Redundant"
                                  Binding="{ReflectionBinding RedundantDisplay}"
                                  Width="100" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      </TabControl>

      <!-- ── Empty state overlay — §8: centered CTA when no scenario loaded ─ -->
      <Grid IsVisible="{ReflectionBinding !Model.HasScenario}"
            IsHitTestVisible="{ReflectionBinding !Model.HasScenario}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
          <TextBlock Text="No scenario loaded."
                     FontSize="14"
                     FontWeight="Medium"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock FontSize="13"
                     Foreground="{StaticResource TextMutedBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="480"
                     Text="Click Open Sample SAS in the toolbar to try the example, or New to start blank." />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <Button Content="Open Sample SAS"
                    Classes="action-btn"
                    Click="OnOpenSampleSasClicked" />
            <Button Content="Open Sample EDS"
                    Classes="action-btn"
                    Click="OnOpenSampleEdsClicked" />
            <Button Content="New"
                    Classes="secondary"
                    Click="OnNewClicked" />
            <Button Content="Open…"
                    Classes="secondary"
                    Click="OnOpenClicked" />
          </StackPanel>
        </StackPanel>
      </Grid>

    </Panel>

  </DockPanel>

</Window>
