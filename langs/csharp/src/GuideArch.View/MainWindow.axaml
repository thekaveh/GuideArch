<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GuideArch.View.MainWindow"
        Title="GuideArch"
        Width="720" Height="480">
  <StackPanel Margin="48" Spacing="12">
    <TextBlock Text="GuideArch" FontSize="32" FontWeight="Bold" />
    <TextBlock Text="C# + Avalonia 12 implementation — bootstrap"
               Foreground="#666" />
    <Border Background="#f4f4f4" Padding="16" CornerRadius="4">
      <!-- ReflectionBinding instead of Binding (the project default per
           AvaloniaUseCompiledBindingsByDefault=true): compiled bindings
           require an x:DataType, but our DataContext is the generic
           ComponentVM<HelloVmx.Greeting> which can't be expressed as a
           XAML type literal. Reflection binding is opt-in per-binding and
           has the same runtime behavior. M2+ will revisit when a richer
           wrapper VM exists. -->
      <TextBlock Text="{ReflectionBinding Model.Message}" FontFamily="Cascadia Code,Consolas,monospace" />
    </Border>
  </StackPanel>
</Window>
