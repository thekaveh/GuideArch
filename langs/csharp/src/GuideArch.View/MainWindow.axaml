<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:scottplot="using:ScottPlot.Avalonia"
        xmlns:local="using:GuideArch.View"
        x:Class="GuideArch.View.MainWindow"
        Title="GuideArch"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource BgPageBrush}"
        FontSize="13">

  <!--
    DataContext is ComponentVM<ScenarioState> — an open generic type that Avalonia's
    compiled-binding engine cannot resolve without a type literal. All bindings into
    the VM use ReflectionBinding intentionally throughout this file.
  -->

  <Window.Resources>
    <local:ToUpperConverter x:Key="ToUpper" />
  </Window.Resources>

  <DockPanel>

    <!-- ================================================================
         TOP TOOLBAR — §6 toolbar: 56px tall, 24px horizontal padding
         ================================================================ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Height="56"
            Padding="24,0">
      <StackPanel Orientation="Horizontal"
                  Spacing="4"
                  VerticalAlignment="Center">

        <!-- Brand: three-triangle motif + name. Same identity as the hero
             and the TS toolbar so the apps read as one product. -->
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">
          <Canvas Width="22" Height="18">
            <Path Data="M2,16 L8,4 L14,16 Z"
                  Fill="{DynamicResource AccentBrush}"
                  Opacity="0.35" />
            <Path Data="M8,16 L13,2 L18,16 Z"
                  Fill="{DynamicResource AccentBrush}"
                  Opacity="0.6" />
            <Path Data="M13,16 L18,7 L22,16 Z"
                  Fill="{DynamicResource AccentBrush}"
                  Opacity="0.95" />
          </Canvas>
          <TextBlock Text="GuideArch"
                     FontWeight="Bold"
                     FontSize="15"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- File operations group -->
        <Button Name="BtnNew"
                Content="New"
                ToolTip.Tip="New scenario"
                Classes="toolbar-btn"
                Click="OnNewClicked" />
        <Button Name="BtnOpen"
                Content="Open…"
                ToolTip.Tip="Open scenario JSON"
                Classes="toolbar-btn"
                Click="OnOpenClicked" />
        <Button Name="BtnSave"
                Content="Save"
                ToolTip.Tip="Save current scenario"
                Classes="toolbar-btn"
                Click="OnSaveClicked"
                IsEnabled="{ReflectionBinding Model.CanSave}" />
        <Button Name="BtnSaveAs"
                Content="Save As…"
                ToolTip.Tip="Save as new file"
                Classes="toolbar-btn"
                Click="OnSaveAsClicked"
                IsEnabled="{ReflectionBinding Model.HasScenario}" />

        <!-- Vertical separator between groups -->
        <Border Width="1"
                Height="24"
                Background="{DynamicResource BorderSubtleBrush}"
                Margin="6,0" />

        <!-- Sample loaders group — accent CTAs per spec/editors.md §1 -->
        <Button Name="BtnOpenSampleSas"
                Content="Sample SAS"
                ToolTip.Tip="Load the bundled SAS (Service-Oriented Architecture) sample"
                Classes="action-btn"
                Click="OnOpenSampleSasClicked" />
        <Button Name="BtnOpenSampleEds"
                Content="Sample EDS"
                ToolTip.Tip="Load the bundled EDS (Enterprise Decision Space) sample"
                Classes="action-btn"
                Click="OnOpenSampleEdsClicked" />

        <!-- Flexible spacer -->
        <Panel HorizontalAlignment="Stretch" />

        <!-- Theme toggle: clicking flips AppVM.Theme between dark and light.
             The label updates from code-behind so the moon/sun feedback
             matches the current theme. -->
        <Button Name="BtnTheme"
                ToolTip.Tip="Toggle theme"
                AutomationProperties.Name="Toggle theme"
                Classes="toolbar-btn icon-btn"
                Width="32"
                Padding="0"
                Click="OnThemeToggleClicked">
          <TextBlock Name="ThemeIcon"
                     Text="🌙"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Button>

        <!-- Solve — primary accent button per spec/editors.md §1 -->
        <Button Name="BtnSolve"
                Content="Solve"
                ToolTip.Tip="Re-run TOPSIS"
                Classes="action-btn"
                Click="OnSolveClicked"
                IsEnabled="{ReflectionBinding Model.HasScenario}" />

      </StackPanel>
    </Border>

    <!-- ================================================================
         BOTTOM STATUS BAR — §6 status bar: 32px tall, 24px horizontal padding
         ================================================================ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Height="32"
            Padding="24,0">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
        <!-- Scenario name -->
        <TextBlock Grid.Column="0"
                   Text="{ReflectionBinding Model.Scenario.Name}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentHoverBrush}"
                   VerticalAlignment="Center"
                   IsVisible="{ReflectionBinding Model.HasScenario}" />
        <!-- File path (basename only; full path in tooltip) -->
        <TextBlock Grid.Column="1"
                   Name="StatusFilePath"
                   FontSize="11"
                   FontFamily="Cascadia Code,Consolas,monospace"
                   Foreground="{DynamicResource TextMutedBrush}"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   IsVisible="False" />
        <!-- Status text -->
        <TextBlock Grid.Column="2"
                   Text="{ReflectionBinding Model.Status}"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0" />

        <!-- Spacer column 3 is *  -->

        <!-- Candidates chip -->
        <Border Grid.Column="4"
                Background="{DynamicResource InfoMutedBrush}"
                CornerRadius="10"
                Padding="8,2"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                IsVisible="{ReflectionBinding Model.HasScenario}">
          <TextBlock Text="{ReflectionBinding Model.Candidates.Length, StringFormat={}{0} candidates}"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{DynamicResource InfoBrush}" />
        </Border>

        <!-- Dirty chip -->
        <Border Grid.Column="5"
                Background="{DynamicResource WarningMutedBrush}"
                CornerRadius="10"
                Padding="8,2"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                IsVisible="{ReflectionBinding Model.IsDirty}">
          <TextBlock Text="unsaved"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{DynamicResource WarningBrush}" />
        </Border>

        <!-- Warnings chip — shows last warning if any -->
        <Border Grid.Column="6"
                Background="{DynamicResource DangerMutedBrush}"
                CornerRadius="10"
                Padding="8,2"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                ToolTip.Tip="{ReflectionBinding Model.LastWarning}"
                IsVisible="{ReflectionBinding !Model.Warnings.IsEmpty}">
          <TextBlock Text="{ReflectionBinding Model.Warnings.Length, StringFormat=⚠ {0} warning(s)}"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{DynamicResource DangerBrush}" />
        </Border>
      </Grid>
    </Border>

    <!-- ================================================================
         MAIN CONTENT — tab strip always visible (§8 empty state inside tabs)
         ================================================================ -->
    <Panel>

      <!-- ── Tab strip — always visible ──────────────────────────────── -->
      <TabControl Name="MainTabs"
                  Background="{DynamicResource BgPageBrush}">

      <!-- ── Tab 1: Decisions ────────────────────────────────────────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M6 3v12 M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M6 15a9 9 0 0 0 9-9" />
            <TextBlock Text="Decisions" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <!-- §SectionHeader — title + subtitle + primary action -->
          <Border Grid.Row="0"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="24,16,24,12"
                  IsVisible="{ReflectionBinding Model.HasScenario}">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Decisions"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Architectural choices you'll resolve by picking one alternative each."
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="+ Add Decision"
                      Click="OnAddDecisionClicked"
                      Classes="action-btn"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Decisions list -->
          <!-- ReflectionBinding: open generic DataContext (see file header) -->
          <DataGrid Grid.Row="1"
                    Name="DecisionsGrid"
                    ItemsSource="{ReflectionBinding Model.DecisionsView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID"
                                  Binding="{ReflectionBinding Id}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <!--
                Name is read-only here because DecisionM is a positional record
                (Id, Name) with init-only setters. Two-way binding into an
                init-only property silently fails — the user could appear to
                edit the name but the change never persisted. Inline editing
                via a CellEditEnded → Mutator.UpdateDecisionName roundtrip is
                a v1.1 backlog item; for v1.0 marking it read-only avoids
                misleading the user.
              -->
              <DataGridTextColumn Header="Name"
                                  Binding="{ReflectionBinding Name}"
                                  IsReadOnly="True"
                                  Width="*" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 2: Alternatives ─────────────────────────────────────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M12 2 2 7l10 5 10-5-10-5Z M2 17l10 5 10-5 M2 12l10 5 10-5" />
            <TextBlock Text="Alternatives" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <!-- §SectionHeader — Add Alternative attaches to the selected
               decision; the selection lives in the grid below. -->
          <Border Grid.Row="0"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="24,16,24,12"
                  IsVisible="{ReflectionBinding Model.HasScenario}">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Alternatives"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Concrete options under each decision; pick one per decision to form a candidate."
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="Select a decision then:"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         FontSize="12" />
              <Button Grid.Column="2"
                      Content="+ Add Alternative"
                      Click="OnAddAlternativeClicked"
                      Classes="action-btn"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Alternatives grouped by decision -->
          <!-- ReflectionBinding: open generic DataContext (see file header) -->
          <DataGrid Grid.Row="1"
                    Name="AlternativesGrid"
                    ItemsSource="{ReflectionBinding Model.AlternativesView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID"
                                  Binding="{ReflectionBinding Id}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Decision ID"
                                  Binding="{ReflectionBinding DecisionId}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <!-- AlternativeM (Id, DecisionId, Name) is init-only — see the
                   Decisions tab comment for the same reasoning. -->
              <DataGridTextColumn Header="Name"
                                  Binding="{ReflectionBinding Name}"
                                  IsReadOnly="True"
                                  Width="*" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 3: Properties ──────────────────────────────────────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M21 4H14 M10 4H3 M21 12H12 M8 12H3 M21 20H16 M12 20H3 M14 2v4 M8 10v4 M16 18v4" />
            <TextBlock Text="Properties" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <!-- §SectionHeader -->
          <Border Grid.Row="0"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="24,16,24,12"
                  IsVisible="{ReflectionBinding Model.HasScenario}">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Properties"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Quality criteria — each with a kind (max / min) and a weight; together they decide how candidates rank."
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="+ Add Property"
                      Click="OnAddPropertyClicked"
                      Classes="action-btn"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Properties table -->
          <!-- ReflectionBinding: open generic DataContext (see file header) -->
          <DataGrid Grid.Row="1"
                    Name="PropertiesGrid"
                    ItemsSource="{ReflectionBinding Model.PropertiesView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="False"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="ID"
                                  Binding="{ReflectionBinding Id}"
                                  Width="220"
                                  IsReadOnly="True"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <!-- PropertyM (Id, Name, Kind, Weight) is init-only — inline
                   edits would silently fail. Marked read-only for v1.0; a
                   CellEditEnded → Mutator.UpdateProperty roundtrip is the
                   v1.1 fix. See the Decisions tab comment for context. -->
              <DataGridTextColumn Header="Name"
                                  Binding="{ReflectionBinding Name}"
                                  IsReadOnly="True"
                                  Width="*" />
              <DataGridTextColumn Header="Kind"
                                  Binding="{ReflectionBinding Kind}"
                                  IsReadOnly="True"
                                  Width="80" />
              <DataGridTextColumn Header="Weight"
                                  Binding="{ReflectionBinding Weight, StringFormat={}{0:F4}}"
                                  IsReadOnly="True"
                                  Width="100"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 4: Coefficients ────────────────────────────────────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M3 3h18v18H3z M3 9h18 M3 15h18 M9 3v18 M15 3v18" />
            <TextBlock Text="Coefficients" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <!-- §SectionHeader -->
          <Border Grid.Row="0"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="24,16,24,12"
                  IsVisible="{ReflectionBinding Model.HasScenario}">
            <StackPanel Spacing="2">
              <TextBlock Text="Coefficients"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Fuzzy values per (alternative, property): lower · modal · upper. Edit to shift how each alternative scores."
                         FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <!-- 2-D matrix: built in code-behind, hosted here -->
          <ScrollViewer Grid.Row="1"
                        Name="CoefficientsScroll"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        Margin="24,0,24,24"
                        IsVisible="{ReflectionBinding Model.HasScenario}">
            <ContentControl Name="CoefficientsContent" />
          </ScrollViewer>

        </Grid>
      </TabItem>

      <!-- ── Tab 5: Constraints ─────────────────────────────────────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M22 3H2l8 9.46V19l4 2v-8.54L22 3Z" />
            <TextBlock Text="Constraints" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*"
              IsVisible="{ReflectionBinding Model.HasScenario}">

          <!-- §SectionHeader -->
          <Border Grid.Row="0"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="24,16,24,12">
            <StackPanel Spacing="2">
              <TextBlock Text="Constraints"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Rules that eliminate candidates: thresholds bound a single property; dependencies require pairings; conflicts forbid them."
                         FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

        <TabControl Grid.Row="1"
                    Background="{DynamicResource BgPageBrush}">

          <!-- Sub-tab: Threshold -->
          <TabItem Header="Threshold">
            <Grid RowDefinitions="Auto,*">

              <StackPanel Grid.Row="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="24,12,24,8">
                <Button Content="Add Threshold"
                        Click="OnAddThresholdClicked"
                        Classes="action-btn" />
              </StackPanel>

              <!-- ReflectionBinding: open generic DataContext (see file header) -->
              <DataGrid Grid.Row="1"
                        Name="ThresholdGrid"
                        ItemsSource="{ReflectionBinding Model.ThresholdConstraintsView}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        Margin="24,0,24,24">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Property ID"
                                      Binding="{ReflectionBinding PropertyId}"
                                      Width="220"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                  <DataGridTextColumn Header="Min"
                                      Binding="{ReflectionBinding Min}"
                                      Width="120"
                                      FontFamily="Cascadia Code,Consolas,monospace" />
                  <DataGridTextColumn Header="Max"
                                      Binding="{ReflectionBinding Max}"
                                      Width="120"
                                      FontFamily="Cascadia Code,Consolas,monospace" />
                </DataGrid.Columns>
              </DataGrid>

            </Grid>
          </TabItem>

          <!-- Sub-tab: Dependency -->
          <TabItem Header="Dependency">
            <Grid RowDefinitions="Auto,*">

              <StackPanel Grid.Row="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="24,12,24,8">
                <Button Content="Add Dependency"
                        Click="OnAddDependencyClicked"
                        Classes="action-btn" />
              </StackPanel>

              <!-- ReflectionBinding: open generic DataContext (see file header) -->
              <DataGrid Grid.Row="1"
                        Name="DependencyGrid"
                        ItemsSource="{ReflectionBinding Model.DependencyConstraintsView}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        Margin="24,0,24,24">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Source Alternative ID"
                                      Binding="{ReflectionBinding SourceAlternativeId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                  <DataGridTextColumn Header="Target Alternative ID"
                                      Binding="{ReflectionBinding TargetAlternativeId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                </DataGrid.Columns>
              </DataGrid>

            </Grid>
          </TabItem>

          <!-- Sub-tab: Conflict -->
          <TabItem Header="Conflict">
            <Grid RowDefinitions="Auto,*">

              <StackPanel Grid.Row="0"
                          Orientation="Horizontal"
                          Spacing="8"
                          Margin="24,12,24,8">
                <Button Content="Add Conflict"
                        Click="OnAddConflictClicked"
                        Classes="action-btn" />
              </StackPanel>

              <!-- ReflectionBinding: open generic DataContext (see file header) -->
              <DataGrid Grid.Row="1"
                        Name="ConflictGrid"
                        ItemsSource="{ReflectionBinding Model.ConflictConstraintsView}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        Margin="24,0,24,24">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Alternative A ID"
                                      Binding="{ReflectionBinding AlternativeAId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                  <DataGridTextColumn Header="Alternative B ID"
                                      Binding="{ReflectionBinding AlternativeBId}"
                                      Width="*"
                                      FontFamily="Cascadia Code,Consolas,monospace"
                                      FontSize="13" />
                </DataGrid.Columns>
              </DataGrid>

            </Grid>
          </TabItem>

        </TabControl>
        </Grid>
      </TabItem>

      <!-- ── Tab 6: Results — split pane (M4) ──────────────────────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M3 3v18h18 M18 17V9 M13 17V5 M8 17v-3" />
            <TextBlock Text="Results" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <!-- Split: left 60% candidates table, right 40% charts -->
          <Grid Grid.Row="1"
                ColumnDefinitions="3*,2*"
                IsVisible="{ReflectionBinding Model.HasScenario}">

            <!-- Left: ranked candidates DataGrid.
                 ItemsSource is owned by code-behind (OnStateChanged), which
                 caps the rows at 50 and skips re-binds on selection-only
                 changes — an AXAML binding here would re-push the full
                 uncapped array on every Model change, defeating both. -->
            <DataGrid Grid.Column="0"
                      Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      IsReadOnly="True"
                      Margin="24,0,12,24"
                      SelectionChanged="OnResultsGridSelectionChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Rank"
                                    Binding="{ReflectionBinding Rank}"
                                    Width="80"
                                    FontFamily="Cascadia Code,Consolas,monospace" />
                <DataGridTextColumn Header="Score"
                                    Binding="{ReflectionBinding Score, StringFormat={}{0:F6}}"
                                    Width="120"
                                    FontFamily="Cascadia Code,Consolas,monospace" />
                <DataGridTextColumn Header="Alternative IDs"
                                    Binding="{ReflectionBinding AlternativeIdsDisplay}"
                                    Width="*"
                                    FontFamily="Cascadia Code,Consolas,monospace"
                                    FontSize="13" />
              </DataGrid.Columns>
            </DataGrid>

            <!-- Right: sub-tabbed ScottPlot charts so each gets full
                 vertical real estate instead of splitting the rail three
                 ways. Default tab = Ranking (the bar chart is the most
                 familiar entry point). All three plots stay constructed
                 so plot state survives tab switches. -->
            <TabControl Grid.Column="1"
                        Name="RightTabs"
                        Margin="12,0,24,24"
                        TabStripPlacement="Top">

              <TabItem Header="Ranking">
                <scottplot:AvaPlot Name="ChartA"
                                   PointerPressed="OnChartAPointerPressed" />
              </TabItem>

              <TabItem Header="Profile">
                <scottplot:AvaPlot Name="ChartB" />
              </TabItem>

              <TabItem Header="Compare">
                <scottplot:AvaPlot Name="ChartC"
                                   PointerPressed="OnChartCPointerPressed" />
              </TabItem>

            </TabControl>

          </Grid>

        </Grid>
      </TabItem>

      <!-- ── Tab 7: Critical Decisions (M4, spec charts.md §4) ─────── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20Z M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
            <TextBlock Text="Critical Decisions" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <TextBlock Grid.Row="0"
                     Text="Critical decisions — sorted ascending by rank (lower score = more critical)."
                     Margin="24,12,24,8"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     IsVisible="{ReflectionBinding Model.HasScenario}" />

          <!-- ReflectionBinding: open generic DataContext -->
          <DataGrid Grid.Row="1"
                    Name="CriticalDecisionsGrid"
                    ItemsSource="{ReflectionBinding Model.CriticalDecisionsView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Rank"
                                  Binding="{ReflectionBinding Rank}"
                                  Width="80"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Decision"
                                  Binding="{ReflectionBinding DecisionName}"
                                  Width="*" />
              <DataGridTextColumn Header="Score"
                                  Binding="{ReflectionBinding Score}"
                                  Width="120"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Triangular value"
                                  Binding="{ReflectionBinding TriangularValue}"
                                  Width="200"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
              <DataGridTextColumn Header="Normalized"
                                  Binding="{ReflectionBinding Normalized}"
                                  Width="200"
                                  FontFamily="Cascadia Code,Consolas,monospace"
                                  FontSize="13" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      <!-- ── Tab 8: Critical Constraints (M4, spec charts.md §5) ───── -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Path Width="14" Height="14"
                  Stretch="Uniform"
                  Stroke="{Binding $parent[TabItem].Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Data="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1Z M12 8v4 M12 16h.01" />
            <TextBlock Text="Critical Constraints" VerticalAlignment="Center" />
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*">

          <TextBlock Grid.Row="0"
                     Text="Critical constraints — sorted descending by eliminated (most-binding first). Redundant rows are faded."
                     Margin="24,12,24,8"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     IsVisible="{ReflectionBinding Model.HasScenario}" />

          <!-- ReflectionBinding: open generic DataContext -->
          <DataGrid Grid.Row="1"
                    Name="CriticalConstraintsGrid"
                    ItemsSource="{ReflectionBinding Model.CriticalConstraintsView}"
                    AutoGenerateColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    IsReadOnly="True"
                    Margin="24,0,24,24"
                    IsVisible="{ReflectionBinding Model.HasScenario}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Index"
                                  Binding="{ReflectionBinding Index}"
                                  Width="80"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Kind"
                                  Binding="{ReflectionBinding Kind}"
                                  Width="120" />
              <DataGridTextColumn Header="Eliminated"
                                  Binding="{ReflectionBinding Eliminated}"
                                  Width="110"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Total"
                                  Binding="{ReflectionBinding Total}"
                                  Width="90"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Eliminated %"
                                  Binding="{ReflectionBinding EliminatedPercent}"
                                  Width="120"
                                  FontFamily="Cascadia Code,Consolas,monospace" />
              <DataGridTextColumn Header="Redundant"
                                  Binding="{ReflectionBinding RedundantDisplay}"
                                  Width="100" />
            </DataGrid.Columns>
          </DataGrid>

        </Grid>
      </TabItem>

      </TabControl>

      <!-- ── First-launch hero — §8: dominates the tab area until a scenario
           loads. Background matches the page so the hero reads as the
           primary canvas, not an overlay floating above blank tabs. -->
      <Grid IsVisible="{ReflectionBinding !Model.HasScenario}"
            IsHitTestVisible="{ReflectionBinding !Model.HasScenario}"
            Background="{DynamicResource BgPageBrush}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    MaxWidth="560">

          <!-- Three nested triangles — mirrors the TS EmptyState illustration
               so users see the same visual identity across impls. Fill uses
               three accent tints (0.08 / 0.16 / 0.24) defined in Colors.axaml
               to match TS EmptyState.svelte fill-opacity values exactly. The
               stroke stays at the full accent brush so the triangle outlines
               remain readable against the page background. -->
          <Canvas Width="120" Height="96" HorizontalAlignment="Center">
            <Path Data="M10,78 L40,18 L70,78 Z"
                  Stroke="{DynamicResource AccentBrush}"
                  StrokeThickness="1.4"
                  Fill="{DynamicResource AccentFillFaintest}" />
            <Path Data="M40,78 L70,12 L100,78 Z"
                  Stroke="{DynamicResource AccentBrush}"
                  StrokeThickness="1.4"
                  Fill="{DynamicResource AccentFillFainter}" />
            <Path Data="M70,78 L92,36 L114,78 Z"
                  Stroke="{DynamicResource AccentBrush}"
                  StrokeThickness="1.4"
                  Fill="{DynamicResource AccentFillFaint}" />
            <Line StartPoint="6,80" EndPoint="118,80"
                  Stroke="{DynamicResource AccentBrush}"
                  StrokeThickness="1"
                  Opacity="0.35" />
          </Canvas>

          <!-- Kicker data is pristine "Welcome to GuideArch" (matches TS and
               Python) and the ToUpper converter renders it as the all-caps
               styling at bind time. Avalonia TextBlock has no native
               text-transform analogue, so the converter stands in. -->
          <TextBlock Text="{Binding Source='Welcome to GuideArch', Converter={StaticResource ToUpper}}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     LetterSpacing="1.2"
                     Foreground="{DynamicResource AccentHoverBrush}"
                     HorizontalAlignment="Center" />

          <TextBlock Text="Pick a software architecture, with fuzzy TOPSIS."
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     TextWrapping="Wrap" />

          <TextBlock FontSize="14"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     LineHeight="22"
                     MaxWidth="520"
                     Margin="0,4,0,12"
                     Text="Model decisions, alternatives, weighted quality properties, and constraints. GuideArch ranks every feasible candidate, then shows which decisions move the result most and which constraints bind hardest. Start with a bundled sample to see it in action." />

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <Button Content="Open Sample SAS"
                    Classes="action-btn"
                    Click="OnOpenSampleSasClicked" />
            <Button Content="Open Sample EDS"
                    Classes="secondary"
                    Click="OnOpenSampleEdsClicked" />
          </StackPanel>
        </StackPanel>
      </Grid>

    </Panel>

  </DockPanel>

</Window>
