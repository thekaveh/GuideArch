<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>

    <!-- ===================== DARK (§2-dark) ===================== -->
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="BgPageColor">#0b0d12</Color>
      <Color x:Key="BgSurfaceColor">#13161d</Color>
      <Color x:Key="BgSurface2Color">#1a1e27</Color>
      <Color x:Key="BgSurface3Color">#252a36</Color>
      <Color x:Key="BorderSubtleColor">#262b36</Color>
      <Color x:Key="BorderStrongColor">#363c4a</Color>
      <Color x:Key="TextPrimaryColor">#e6e7ed</Color>
      <Color x:Key="TextSecondaryColor">#9298a8</Color>
      <Color x:Key="TextMutedColor">#5e6478</Color>
      <Color x:Key="TextInverseColor">#0b0d12</Color>
      <Color x:Key="AccentColor">#8b5cf6</Color>
      <Color x:Key="AccentHoverColor">#a78bfa</Color>
      <Color x:Key="AccentMutedColor">#3d2a6b</Color>
      <Color x:Key="AccentOnColor">#ffffff</Color>
      <Color x:Key="SuccessColor">#10b981</Color>
      <Color x:Key="WarningColor">#f59e0b</Color>
      <Color x:Key="DangerColor">#ef4444</Color>
      <Color x:Key="InfoColor">#3b82f6</Color>
      <Color x:Key="FuzzyPositiveColor">#34d399</Color>
      <Color x:Key="FuzzyAverageColor">#fbbf24</Color>
      <Color x:Key="FuzzyNegativeColor">#fb7185</Color>

      <SolidColorBrush x:Key="BgPageBrush" Color="{StaticResource BgPageColor}" />
      <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurfaceColor}" />
      <SolidColorBrush x:Key="BgSurface2Brush" Color="{StaticResource BgSurface2Color}" />
      <SolidColorBrush x:Key="BgSurface3Brush" Color="{StaticResource BgSurface3Color}" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />
      <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
      <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverseColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
      <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
      <SolidColorBrush x:Key="AccentOnBrush" Color="{StaticResource AccentOnColor}" />
      <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
      <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
      <SolidColorBrush x:Key="SuccessMutedBrush" Color="{StaticResource SuccessColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="WarningMutedBrush" Color="{StaticResource WarningColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="DangerMutedBrush" Color="{StaticResource DangerColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="InfoMutedBrush" Color="{StaticResource InfoColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="AccentFillFaintest" Color="{StaticResource AccentColor}" Opacity="0.08" />
      <SolidColorBrush x:Key="AccentFillFainter" Color="{StaticResource AccentColor}" Opacity="0.16" />
      <SolidColorBrush x:Key="AccentFillFaint" Color="{StaticResource AccentColor}" Opacity="0.24" />
      <SolidColorBrush x:Key="FuzzyPositiveBrush" Color="{StaticResource FuzzyPositiveColor}" />
      <SolidColorBrush x:Key="FuzzyAverageBrush" Color="{StaticResource FuzzyAverageColor}" />
      <SolidColorBrush x:Key="FuzzyNegativeBrush" Color="{StaticResource FuzzyNegativeColor}" />

      <!-- §3.2 Solve — gradient (dark) so the primary control stands out. -->
      <LinearGradientBrush x:Key="SolveBackgroundBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="{StaticResource AccentColor}" />
        <GradientStop Offset="1" Color="{StaticResource AccentHoverColor}" />
      </LinearGradientBrush>
    </ResourceDictionary>

    <!-- ===================== LIGHT (§2-light) ===================== -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="BgPageColor">#ffffff</Color>
      <Color x:Key="BgSurfaceColor">#fbfbfd</Color>
      <Color x:Key="BgSurface2Color">#f3f4f8</Color>
      <Color x:Key="BgSurface3Color">#eaecf3</Color>
      <Color x:Key="BorderSubtleColor">#eef0f4</Color>
      <Color x:Key="BorderStrongColor">#dfe2ec</Color>
      <Color x:Key="TextPrimaryColor">#1a1f36</Color>
      <Color x:Key="TextSecondaryColor">#5a6072</Color>
      <Color x:Key="TextMutedColor">#8a90a2</Color>
      <Color x:Key="TextInverseColor">#ffffff</Color>
      <Color x:Key="AccentColor">#6b4ce0</Color>
      <Color x:Key="AccentHoverColor">#5a3dd0</Color>
      <Color x:Key="AccentMutedColor">#f0ecfd</Color>
      <Color x:Key="AccentOnColor">#ffffff</Color>
      <Color x:Key="SuccessColor">#0ea371</Color>
      <Color x:Key="WarningColor">#b8801a</Color>
      <Color x:Key="DangerColor">#dc3a3a</Color>
      <Color x:Key="InfoColor">#3a6fd8</Color>
      <Color x:Key="FuzzyPositiveColor">#0ea371</Color>
      <Color x:Key="FuzzyAverageColor">#d9a014</Color>
      <Color x:Key="FuzzyNegativeColor">#e5566f</Color>

      <SolidColorBrush x:Key="BgPageBrush" Color="{StaticResource BgPageColor}" />
      <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurfaceColor}" />
      <SolidColorBrush x:Key="BgSurface2Brush" Color="{StaticResource BgSurface2Color}" />
      <SolidColorBrush x:Key="BgSurface3Brush" Color="{StaticResource BgSurface3Color}" />
      <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />
      <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
      <SolidColorBrush x:Key="TextInverseBrush" Color="{StaticResource TextInverseColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
      <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
      <SolidColorBrush x:Key="AccentOnBrush" Color="{StaticResource AccentOnColor}" />
      <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
      <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
      <SolidColorBrush x:Key="SuccessMutedBrush" Color="{StaticResource SuccessColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="WarningMutedBrush" Color="{StaticResource WarningColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="DangerMutedBrush" Color="{StaticResource DangerColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="InfoMutedBrush" Color="{StaticResource InfoColor}" Opacity="0.14" />
      <SolidColorBrush x:Key="AccentFillFaintest" Color="{StaticResource AccentColor}" Opacity="0.08" />
      <SolidColorBrush x:Key="AccentFillFainter" Color="{StaticResource AccentColor}" Opacity="0.16" />
      <SolidColorBrush x:Key="AccentFillFaint" Color="{StaticResource AccentColor}" Opacity="0.24" />
      <SolidColorBrush x:Key="FuzzyPositiveBrush" Color="{StaticResource FuzzyPositiveColor}" />
      <SolidColorBrush x:Key="FuzzyAverageBrush" Color="{StaticResource FuzzyAverageColor}" />
      <SolidColorBrush x:Key="FuzzyNegativeBrush" Color="{StaticResource FuzzyNegativeColor}" />

      <!-- §3.2 Solve — flat accent fill (light); the drop-shadow lives on the style. -->
      <SolidColorBrush x:Key="SolveBackgroundBrush" Color="{StaticResource AccentColor}" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
