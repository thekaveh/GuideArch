<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ================================================================
       GuideArch Design System — Component Styles
       ================================================================ -->

  <!-- ── §5.1 Buttons ──────────────────────────────────────────────── -->

  <!-- Base button reset — applied to all GuideArch buttons -->
  <Style Selector="Button.ga-btn">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- Primary — solid accent background -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentOnBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
  </Style>
  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
  </Style>

  <!-- Secondary — transparent bg, border-strong border -->
  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
  </Style>

  <!-- Ghost — transparent, text-secondary, no border. Toolbar actions. -->
  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
  </Style>
  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <!-- Destructive — same shape as secondary, danger text and border -->
  <Style Selector="Button.destructive">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.destructive:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
  </Style>

  <!-- toolbar-btn — ghost style for the top toolbar buttons -->
  <Style Selector="Button.toolbar-btn">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
  </Style>
  <Style Selector="Button.toolbar-btn:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <!-- icon-btn — square 32x32 ghost icon button (4px radius), subtle border -->
  <Style Selector="Button.icon-btn">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.icon-btn:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <!-- action-btn — primary style for in-tab "Add …" actions -->
  <Style Selector="Button.action-btn">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentOnBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
  </Style>
  <Style Selector="Button.action-btn:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
  </Style>

  <!-- solve-btn — the signature primary control. Background is the theme-variant
       SolveBackgroundBrush (gradient in dark, flat accent in light); the soft
       accent drop-shadow reads as a glow in dark and a drop-shadow in light. -->
  <Style Selector="Button.solve-btn">
    <Setter Property="Background" Value="{DynamicResource SolveBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentOnBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Effect">
      <DropShadowEffect Color="{DynamicResource AccentColor}"
                        BlurRadius="14" OffsetX="0" OffsetY="2" Opacity="0.5" />
    </Setter>
  </Style>
  <Style Selector="Button.solve-btn /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SolveBackgroundBrush}" />
  </Style>
  <Style Selector="Button.solve-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
  </Style>
  <Style Selector="Button.solve-btn:disabled">
    <Setter Property="Effect">
      <DropShadowEffect Color="Transparent" BlurRadius="0" Opacity="0" />
    </Setter>
  </Style>

  <!-- ── §5.2 Inputs ───────────────────────────────────────────────── -->

  <Style Selector="TextBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="NumericUpDown">
    <Setter Property="Height" Value="32" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- §5.2 Input focus — accent border COLOR on focus (keyboard/pointer).
       NB: do NOT also bump BorderThickness (1→2) here — growing the border
       re-measures the control and visibly shifts it up, most obviously on the
       dense Coefficients cell inputs. The gray→accent color change is a clear
       focus signal on its own and is layout-stable. -->
  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="TextBox:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="NumericUpDown:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>
  <Style Selector="ComboBox:focus-within">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- ── §5.3 DataGrid ─────────────────────────────────────────────── -->

  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource BgPageBrush}" />
    <Setter Property="RowBackground" Value="{DynamicResource BgPageBrush}" />
    <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
  </Style>

  <!-- DataGrid column header -->
  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="SeparatorBrush" Value="{DynamicResource BorderSubtleBrush}" />
  </Style>

  <!-- DataGrid body rows -->
  <Style Selector="DataGridRow">
    <Setter Property="Height" Value="36" />
    <Setter Property="Background" Value="{DynamicResource BgPageBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- DataGrid row hover -->
  <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="{DynamicResource BgSurface2Brush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- DataGrid row selected -->
  <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Fill" Value="{DynamicResource AccentMutedBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- §5.3 Selected row — 2px accent left border (the fill is set on the
       BackgroundRectangle above). -->
  <Style Selector="DataGridRow:selected">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="2,0,0,0" />
  </Style>

  <!-- DataGrid cells -->
  <Style Selector="DataGridCell">
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <!-- ── §5.4 TabControl / TabItem ─────────────────────────────────── -->

  <Style Selector="TabControl">
    <Setter Property="Background" Value="{DynamicResource BgPageBrush}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="TabItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>

  <Style Selector="TabItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource BgSurface2Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>

  <!-- Suppress Fluent's built-in selection pipe so it doesn't double up with the 2px accent underline -->
  <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <!-- ── §5.5 Card borders ──────────────────────────────────────────── -->

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <!-- ── §5.10 Dialog card — bg-surface-3, 1px border-strong, 8px radius.
       Padding (20/24) and MaxWidth (28rem=448) are set here so the card
       hosts both error and confirm bodies uniformly. Brushes are
       DynamicResource so the dialog retints with the active theme. -->
  <Style Selector="Border.dialog-card">
    <Setter Property="Background" Value="{DynamicResource BgSurface3Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="24,20,24,20" />
    <Setter Property="MaxWidth" Value="448" />
    <Setter Property="BoxShadow" Value="0 12 40 0 #99000000" />
  </Style>

  <!-- Dialog title — 15/SemiBold text-primary. -->
  <Style Selector="TextBlock.dialog-title">
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <!-- Dialog body — 13px text-secondary, wrapping. -->
  <Style Selector="TextBlock.dialog-body">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

</Styles>
